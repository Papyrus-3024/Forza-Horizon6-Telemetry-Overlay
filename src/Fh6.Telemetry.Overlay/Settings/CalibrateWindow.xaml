<Window x:Class="Fh6.Telemetry.Overlay.Settings.CalibrateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Calibration" Width="940" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <StackPanel Margin="14">

        <TextBlock x:Name="InstructionText" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Drive to a recognizable spot, click Capture, then click that exact spot on the map. Repeat for 3+ spread-out spots, then Fit &amp; Save. The game or a replay must be running so the captured position is current."/>

        <!-- Map image area with click-dot overlay -->
        <Border x:Name="MapBorder" Width="800" Height="800" HorizontalAlignment="Left"
                Background="#FF1A1A1A" Margin="0,0,0,10">
            <Grid>
                <Image x:Name="MapImage" Width="800" Height="800"
                       Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top"
                       MouseLeftButtonDown="OnMapClick" Cursor="Crosshair"/>
                <Canvas x:Name="DotCanvas" Width="800" Height="800"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Status row -->
        <TextBlock x:Name="StatusLabel" Margin="0,0,0,8" FontSize="12"
                   Foreground="#FF2080FF" TextWrapping="Wrap"/>

        <!-- Capture button -->
        <Button x:Name="CaptureBtn" Content="Capture car position"
                Width="160" HorizontalAlignment="Left" Margin="0,0,0,10"
                Click="OnCapture"/>

        <!-- Points list -->
        <TextBlock Text="Calibration points:" Margin="0,0,0,4"/>
        <ListBox x:Name="PointsList" Height="110" Margin="0,0,0,10"
                 FontFamily="Consolas" FontSize="11"/>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
            <Button x:Name="RemoveLastBtn" Content="Remove last" Width="90"
                    Margin="0,0,8,0" Click="OnRemoveLast"/>
            <Button x:Name="ClearBtn" Content="Clear" Width="70"
                    Margin="0,0,8,0" Click="OnClear"/>
            <Button x:Name="FitSaveBtn" Content="Fit &amp; Save" Width="90"
                    Margin="0,0,8,0" IsEnabled="False" Click="OnFitSave"/>
            <Button Content="Cancel" Width="70" IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
