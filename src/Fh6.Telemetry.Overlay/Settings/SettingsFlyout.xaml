<UserControl x:Class="Fh6.Telemetry.Overlay.Settings.SettingsFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="384"
             TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Fld" Color="#1E2630"/>
        <SolidColorBrush x:Key="FldBorder" Color="#3A4654"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8EDF2"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8EDF2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Fld}"/>
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="{StaticResource FldBorder}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="CaretBrush" Value="#F2F4F7"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark combo box: stock Aero ignores Background/Foreground on the selection box. -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="Background" Value="{StaticResource Fld}"/>
            <Setter Property="BorderBrush" Value="{StaticResource FldBorder}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1" CornerRadius="3">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0"
                                                  Data="M0,0 L4,4 L8,0 Z" Fill="#C8D2DD"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="7,0,20,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" Focusable="False"
                                   AllowsTransparency="True" PopupAnimation="Slide">
                                <Border Background="#1E2630" BorderBrush="#3A4654" BorderThickness="1" CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220"><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Fld}"/>
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="{StaticResource FldBorder}"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A93A0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Dark tabs -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent" Margin="0,0,0,-1"/>
                            </Border>
                            <ContentPresenter ContentSource="SelectedContent" Margin="0,8,0,0"/>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#9AA4B2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="b" Padding="6,4" Margin="0,0,1,0" CornerRadius="5,5,0,0" Background="Transparent">
                            <ContentPresenter ContentSource="Header" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1E2630"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TabBody" TargetType="StackPanel">
            <Setter Property="Margin" Value="14,2,14,0"/>
        </Style>
    </UserControl.Resources>

    <!-- Card with shadow (layered like the widgets) -->
    <Grid>
        <Border Background="#F00C1016" BorderBrush="#3A4654" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}" CacheMode="BitmapCache"/>
        <Border CornerRadius="10" Padding="0">
            <DockPanel>
                <!-- Header (drag handle — move the panel by dragging here) -->
                <Border x:Name="DragHandle" DockPanel.Dock="Top" Background="#01000000"
                        Cursor="SizeAll" Padding="14,10,8,6">
                    <Grid>
                        <TextBlock Text="⚙  SETTINGS" FontWeight="Bold" FontSize="13"
                                   Foreground="#F2F4F7" VerticalAlignment="Center"/>
                        <TextBlock Text="drag to move" Style="{StaticResource Hint}"
                                   HorizontalAlignment="Right" Margin="0,0,28,0" VerticalAlignment="Center"/>
                        <Button x:Name="CloseBtn" Content="✕" Width="22" Height="22"
                                HorizontalAlignment="Right" Padding="0" Click="OnClose"/>
                    </Grid>
                </Border>

                <!-- Apply bar pinned to bottom -->
                <Border DockPanel.Dock="Bottom" BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Padding="14,8">
                    <Button Content="Apply" Width="80" HorizontalAlignment="Right" Click="OnApply"/>
                </Border>

                <!-- Tabs -->
                <TabControl Margin="10,8,10,4" Background="Transparent">
                    <!-- GENERAL -->
                    <TabItem Header="General">
                        <StackPanel Style="{StaticResource TabBody}">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Port"/>
                                    <TextBox x:Name="PortBox" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Listen address"/>
                                    <TextBox x:Name="AddressBox" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Layout" VerticalAlignment="Center" Margin="0,3,8,3"/>
                                <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="LayoutBox" Margin="0,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,3,8,3"/>
                                <Slider    Grid.Row="1" Grid.Column="1" x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0"
                                           TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="HUD scale" VerticalAlignment="Center" Margin="0,3,8,3"/>
                                <Slider    Grid.Row="2" Grid.Column="1" x:Name="HudScaleSlider" Minimum="0.5" Maximum="2.5"
                                           TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Theme" VerticalAlignment="Center" Margin="0,3,8,3"/>
                                <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="ThemePresetBox" Margin="0,3"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Accent" VerticalAlignment="Center" Margin="0,3,8,3"/>
                                <TextBox   Grid.Row="4" Grid.Column="1" x:Name="CustomAccentBox" Margin="0,3"
                                           ToolTip="#RRGGBB or #AARRGGBB — blank uses preset accent"/>
                            </Grid>
                        </StackPanel>
                    </TabItem>

                    <!-- WIDGETS -->
                    <TabItem Header="Widgets">
                        <StackPanel x:Name="WidgetRows" Style="{StaticResource TabBody}"/>
                    </TabItem>

                    <!-- CHART -->
                    <TabItem Header="Chart">
                        <StackPanel Style="{StaticResource TabBody}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Time window" Width="90" VerticalAlignment="Center"/>
                                <ComboBox x:Name="ChartWindowBox" Width="90"/>
                            </StackPanel>
                            <TextBlock Text="Series" Foreground="#9AA4B2" FontSize="10" Margin="0,0,0,4"/>
                            <WrapPanel x:Name="ChartSeriesRows"/>
                        </StackPanel>
                    </TabItem>

                    <!-- LAYOUTS -->
                    <TabItem Header="Layouts">
                        <StackPanel Style="{StaticResource TabBody}">
                            <TextBlock Text="Saved layouts"/>
                            <ComboBox x:Name="SavedLayoutBox" Margin="0,3,0,6"/>
                            <TextBox x:Name="LayoutNameBox" Margin="0,0,0,6"
                                     ToolTip="Type a name to save or rename to"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Save"   Width="58" Margin="0,0,5,0" Click="OnSaveLayout"/>
                                <Button Content="Load"   Width="58" Margin="0,0,5,0" Click="OnLoadLayout"/>
                                <Button Content="Rename" Width="62" Margin="0,0,5,0" Click="OnRenameLayout"/>
                                <Button Content="Delete" Width="58"                  Click="OnDeleteLayout"/>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- DIAGNOSTICS -->
                    <TabItem Header="Health">
                        <StackPanel Style="{StaticResource TabBody}">
                            <TextBlock Text="Telemetry health" Foreground="#9AA4B2" FontSize="10" Margin="0,0,0,4"/>
                            <Border Background="#1E2630" BorderBrush="{StaticResource FldBorder}" BorderThickness="1"
                                    CornerRadius="5" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="HealthState" Text="—" FontSize="15" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Diagnostics}" Style="{StaticResource Hint}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="If no data arrives:" Margin="0,0,0,3"/>
                            <TextBlock Style="{StaticResource Hint}"
                                       Text="• FH6 → Settings → HUD and Gameplay → Data Out = ON&#x0a;• Data Out IP points at THIS pc (127.0.0.1 if same machine), matching port&#x0a;• Data is only sent while actively driving (not menus/pause/replay)&#x0a;• Microsoft Store / Game Pass build is sandboxed from localhost — apply the loopback exemption:"/>
                            <Border Background="#11161D" BorderBrush="{StaticResource FldBorder}" BorderThickness="1"
                                    CornerRadius="4" Padding="6,4" Margin="0,5,0,4">
                                <TextBlock x:Name="LoopbackCmd" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"
                                           Foreground="#C8D2DD"
                                           Text="CheckNetIsolation LoopbackExempt -a -n=&quot;Microsoft.624F8B84B80_8wekyb3d8bbwe&quot;"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Copy command" Click="OnCopyLoopback"/>
                                <TextBlock x:Name="CopyHint" Style="{StaticResource Hint}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Hint}" Margin="0,6,0,0"
                                       Text="Tip: 'fh6 doctor' in a terminal samples the port standalone."/>
                        </StackPanel>
                    </TabItem>

                    <!-- EXPORT -->
                    <TabItem Header="Export">
                        <StackPanel Style="{StaticResource TabBody}">
                            <TextBlock Text="Export a capture to CSV" Foreground="#9AA4B2" FontSize="10" Margin="0,0,0,4"/>
                            <TextBlock Text="Capture file (.jsonl)"/>
                            <Grid Margin="0,3,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="CapturePathBox" IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Click="OnBrowseCapture"/>
                            </Grid>
                            <Button Content="Export to CSV" HorizontalAlignment="Left" Click="OnExportCsv"/>
                            <TextBlock x:Name="ExportResult" Style="{StaticResource Hint}" Margin="0,6,0,0"/>
                            <TextBlock Style="{StaticResource Hint}" Margin="0,8,0,0"
                                       Text="Produces a flat, pandas-friendly CSV (one row per packet). Equivalent to 'fh6 export'."/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
