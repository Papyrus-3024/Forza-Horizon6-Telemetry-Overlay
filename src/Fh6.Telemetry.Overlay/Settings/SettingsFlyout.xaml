<UserControl x:Class="Fh6.Telemetry.Overlay.Settings.SettingsFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="330"
             TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <!-- Lightweight dark styling so the panel reads as part of the HUD, not a stock dialog.
             Implicit styles (no full ControlTemplates) keep this maintainable. -->
        <SolidColorBrush x:Key="Fld" Color="#1E2630"/>
        <SolidColorBrush x:Key="FldBorder" Color="#3A4654"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8EDF2"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8EDF2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Fld}"/>
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="{StaticResource FldBorder}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="CaretBrush" Value="#F2F4F7"/>
        </Style>
        <!-- Dark combo item (the default would be light with dark hover). -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark combo box: the stock Aero template ignores Background/Foreground on the
             selection box, so a compact custom template is needed to match the panel. -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="Background" Value="{StaticResource Fld}"/>
            <Setter Property="BorderBrush" Value="{StaticResource FldBorder}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1" CornerRadius="3">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0"
                                                  Data="M0,0 L4,4 L8,0 Z" Fill="#C8D2DD"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="7,0,20,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" Focusable="False"
                                   AllowsTransparency="True" PopupAnimation="Slide">
                                <Border Background="#1E2630" BorderBrush="#3A4654" BorderThickness="1" CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220"><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Fld}"/>
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="{StaticResource FldBorder}"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <!-- Section header -->
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Fh6.Accent}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,5"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A93A0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <!-- Card with shadow (layered like the widgets) -->
    <Grid>
        <Border Background="#F00C1016" BorderBrush="#3A4654" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}" CacheMode="BitmapCache"/>
        <Border CornerRadius="10" Padding="0">
            <DockPanel>
                <!-- Header -->
                <Grid DockPanel.Dock="Top" Margin="14,12,10,4">
                    <TextBlock Text="⚙  SETTINGS" FontWeight="Bold" FontSize="13"
                               Foreground="#F2F4F7" VerticalAlignment="Center"/>
                    <Button x:Name="CloseBtn" Content="✕" Width="22" Height="22"
                            HorizontalAlignment="Right" Padding="0" Click="OnClose"/>
                </Grid>

                <!-- Apply bar pinned to bottom -->
                <Border DockPanel.Dock="Bottom" BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="DiagText" Text="{Binding Diagnostics}"
                                   Style="{StaticResource Hint}" VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <Button Content="Apply" Width="72" Click="OnApply"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable body -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="640" Padding="14,0,12,0">
                    <StackPanel>
                        <TextBlock Text="CONNECTION" Style="{StaticResource Section}" Margin="0,4,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Port"/>
                                <TextBox x:Name="PortBox" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Listen address"/>
                                <TextBox x:Name="AddressBox" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Style="{StaticResource Hint}" Margin="0,3,0,0"
                                   Text="0.0.0.0 = all interfaces (recommended). 127.0.0.1 = loopback only. Run 'fh6 doctor' if no data."/>

                        <TextBlock Text="APPEARANCE" Style="{StaticResource Section}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Layout" VerticalAlignment="Center" Margin="0,3"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="LayoutBox" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,3,8,3"/>
                            <Slider    Grid.Row="1" Grid.Column="1" x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0"
                                       TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="HUD scale" VerticalAlignment="Center" Margin="0,3,8,3"/>
                            <Slider    Grid.Row="2" Grid.Column="1" x:Name="HudScaleSlider" Minimum="0.5" Maximum="2.5"
                                       TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Theme" VerticalAlignment="Center" Margin="0,3"/>
                            <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="ThemePresetBox" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Accent" VerticalAlignment="Center" Margin="0,3,8,3"/>
                            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="CustomAccentBox" Margin="0,3"
                                       ToolTip="#RRGGBB or #AARRGGBB — blank uses preset accent"/>
                        </Grid>

                        <TextBlock Text="CHART" Style="{StaticResource Section}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Time window" Width="90" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ChartWindowBox" Width="90"/>
                        </StackPanel>
                        <WrapPanel x:Name="ChartSeriesRows"/>

                        <TextBlock Text="WIDGETS" Style="{StaticResource Section}"/>
                        <StackPanel x:Name="WidgetRows"/>

                        <TextBlock Text="SAVED LAYOUTS" Style="{StaticResource Section}"/>
                        <ComboBox x:Name="SavedLayoutBox" Margin="0,0,0,5"/>
                        <TextBox x:Name="LayoutNameBox" Margin="0,0,0,5"
                                 ToolTip="Type a name to save or rename to"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Save"   Width="56" Margin="0,0,5,0" Click="OnSaveLayout"/>
                            <Button Content="Load"   Width="56" Margin="0,0,5,0" Click="OnLoadLayout"/>
                            <Button Content="Rename" Width="60" Margin="0,0,5,0" Click="OnRenameLayout"/>
                            <Button Content="Delete" Width="56"                  Click="OnDeleteLayout"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
