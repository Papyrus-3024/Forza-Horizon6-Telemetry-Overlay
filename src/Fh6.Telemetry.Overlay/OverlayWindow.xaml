<Window x:Class="Fh6.Telemetry.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="FH6 Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="40" Top="40">
    <Border x:Name="Root" Padding="6" Background="#01000000"
            MouseEnter="Root_MouseEnter" MouseLeave="Root_MouseLeave">
        <Grid>
            <StackPanel>
                <TextBlock Text="{Binding Status}" Foreground="#FFE05A5A" FontFamily="Consolas" FontSize="11"/>
                <ContentControl x:Name="LayoutHost" />
            </StackPanel>
            <!-- Quit button: visible on hover, works when window is interactive (edit mode / not click-through).
                 F7 global hotkey is the gameplay-time quit. -->
            <Button x:Name="QuitButton"
                    Width="16" Height="16"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,0,2,0"
                    Opacity="0"
                    Click="QuitButton_Click"
                    ToolTip="Close overlay (F7)">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#A6080A08"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="3">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <TextBlock Text="✕" FontSize="9" Foreground="White"/>
            </Button>
            <!-- Resize grip: visible only in edit mode (F8). Drag vertically to scale the overlay. -->
            <Thumb x:Name="ResizeGrip"
                   Width="12" Height="12"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Visibility="Collapsed"
                   Cursor="SizeNWSE"
                   DragDelta="ResizeGrip_DragDelta">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#99FFFF00" CornerRadius="2"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>
