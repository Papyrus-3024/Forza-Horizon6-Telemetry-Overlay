<Window x:Class="Fh6.Telemetry.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:layouts="clr-namespace:Fh6.Telemetry.Overlay.Layouts"
        Title="FH6 Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border x:Name="Root" Background="#01000000"
            MouseEnter="Root_MouseEnter" MouseLeave="Root_MouseLeave">
        <Grid>
            <!-- FreeLayout canvas fills the entire window -->
            <layouts:FreeLayout x:Name="FreeLayoutHost"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>

            <!-- Status text pinned top-left, non-movable -->
            <TextBlock Text="{Binding Status}"
                       Foreground="#FFE05A5A"
                       FontFamily="Consolas"
                       FontSize="11"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="6,4,0,0"
                       IsHitTestVisible="False"/>

            <!-- Quit button: visible on hover, works when window is interactive (edit mode / not click-through).
                 F7 global hotkey is the gameplay-time quit. -->
            <Button x:Name="QuitButton"
                    Width="16" Height="16"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    Opacity="0"
                    Click="QuitButton_Click"
                    ToolTip="Close overlay (F7)">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#A6080A08"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="3">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <TextBlock Text="✕" FontSize="9" Foreground="White"/>
            </Button>
        </Grid>
    </Border>
</Window>
