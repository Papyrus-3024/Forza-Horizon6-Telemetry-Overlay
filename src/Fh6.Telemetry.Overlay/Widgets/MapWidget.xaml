<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.MapWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="240" Height="240"
             SizeChanged="OnSizeChanged">
    <Border Background="#C8121821"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            CornerRadius="8" Padding="4">
        <Grid>
            <!-- Map image — Uniform keeps the full image visible regardless of resolution -->
            <Image x:Name="MapImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>
            <!-- Marker overlay canvas — same size as the Grid cell; marker is positioned in code-behind -->
            <Canvas x:Name="Overlay" IsHitTestVisible="False">
                <Ellipse x:Name="Marker"
                         Width="10" Height="10"
                         Fill="#E05A5A"
                         Stroke="White" StrokeThickness="1.2"
                         Visibility="Collapsed"/>
            </Canvas>
            <!-- Placeholder shown when no image or calibration is available -->
            <TextBlock x:Name="Placeholder"
                       Foreground="#99FFFFFF" FontSize="10" FontFamily="Consolas"
                       TextWrapping="Wrap" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
