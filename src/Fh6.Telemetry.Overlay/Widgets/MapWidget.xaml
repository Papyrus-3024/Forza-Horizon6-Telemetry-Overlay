<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.MapWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="240" Height="240"
             SizeChanged="OnSizeChanged">
    <!-- Fixed-size viewport: map scrolls under a centred car marker -->
    <Border x:Name="Viewport"
            Background="#C8121821"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Grid>
            <!-- Map image at natural size; a TransformGroup pans/zooms it so the car is centred -->
            <Image x:Name="MapImage"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   RenderTransformOrigin="0,0">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="MapScale"/>
                        <TranslateTransform x:Name="MapTranslate"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>

            <!-- Fixed centred marker — always at viewport centre, never moves -->
            <Ellipse x:Name="Marker"
                     Width="10" Height="10"
                     Fill="#E05A5A"
                     Stroke="White" StrokeThickness="1.2"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Visibility="Collapsed"
                     IsHitTestVisible="False"/>

            <!-- Placeholder shown when no image is available -->
            <TextBlock x:Name="Placeholder"
                       Foreground="#99FFFFFF" FontSize="10" FontFamily="Consolas"
                       TextWrapping="Wrap" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
