<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.PowerTorqueWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#C8121821"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            CornerRadius="8" Padding="10,6">
        <StackPanel>
            <TextBlock Text="POWER"
                       Foreground="#80FFFFFF" FontSize="8" FontFamily="Consolas"
                       />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding PowerHp}"
                           Foreground="#F2F4F7" FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Text=" hp"
                           Foreground="#80FFFFFF" FontSize="9" FontFamily="Consolas"
                           VerticalAlignment="Bottom" Margin="3,0,0,2"/>
            </StackPanel>
            <TextBlock Text="TORQUE"
                       Foreground="#80FFFFFF" FontSize="8" FontFamily="Consolas"
                       Margin="0,5,0,0"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TorqueLbFt}"
                           Foreground="#99FFFFFF" FontSize="15" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Text=" lb·ft"
                           Foreground="#80FFFFFF" FontSize="9" FontFamily="Consolas"
                           VerticalAlignment="Bottom" Margin="3,0,0,2"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
