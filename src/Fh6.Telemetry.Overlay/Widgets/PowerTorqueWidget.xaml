<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.PowerTorqueWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display">
    <Border Background="{DynamicResource Fh6.Surface}"
            BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
            CornerRadius="10" Padding="12,8">
        <StackPanel>
            <TextBlock Text="POWER"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding PowerHp}"
                           Foreground="{DynamicResource Fh6.TextPrimary}" FontSize="24" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Text=" hp"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Bottom" Margin="3,0,0,3"/>
            </StackPanel>
            <TextBlock Text="TORQUE"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" Margin="0,6,0,0"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TorqueLbFt}"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="17" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Text=" lb·ft"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Bottom" Margin="3,0,0,3"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
