<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.PowerTorqueWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200"
             TextOptions.TextFormattingMode="Display">
    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}" CacheMode="BitmapCache"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="12,8">
        <StackPanel>

            <!-- Power row -->
            <StackPanel Margin="0,0,0,8">
                <DockPanel Margin="0,0,0,3">
                    <TextBlock Text="POWER"
                               Foreground="{DynamicResource Fh6.TextLabel}" FontSize="9" FontFamily="Consolas"
                               FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Bottom"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="PowerValue"
                                   Foreground="{DynamicResource Fh6.TextPrimary}"
                                   FontFamily="Consolas" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text=" hp"
                                   Foreground="{DynamicResource Fh6.TextSecondary}"
                                   FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                    </StackPanel>
                </DockPanel>
                <!-- Power bar -->
                <Border Height="6" CornerRadius="3" Background="#18FFFFFF">
                    <Grid>
                        <Rectangle x:Name="PowerBar"
                                   Height="6" HorizontalAlignment="Left"
                                   RadiusX="3" RadiusY="3">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4FD1A5" Offset="0"/>
                                    <GradientStop Color="#FF2BFFA0" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                            <Rectangle.Effect>
                                <DropShadowEffect Color="#4FD1A5" BlurRadius="7" ShadowDepth="0" Opacity="0.7"/>
                            </Rectangle.Effect>
                        </Rectangle>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#18FFFFFF" Margin="0,0,0,8"/>

            <!-- Torque row -->
            <StackPanel>
                <DockPanel Margin="0,0,0,3">
                    <TextBlock Text="TORQUE"
                               Foreground="{DynamicResource Fh6.TextLabel}" FontSize="9" FontFamily="Consolas"
                               FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Bottom"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TorqueValue"
                                   Foreground="{DynamicResource Fh6.TextSecondary}"
                                   FontFamily="Consolas" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" lb·ft"
                                   Foreground="{DynamicResource Fh6.TextSecondary}"
                                   FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                    </StackPanel>
                </DockPanel>
                <!-- Torque bar -->
                <Border Height="6" CornerRadius="3" Background="#18FFFFFF">
                    <Grid>
                        <Rectangle x:Name="TorqueBar"
                                   Height="6" HorizontalAlignment="Left"
                                   RadiusX="3" RadiusY="3">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFE0B83A" Offset="0"/>
                                    <GradientStop Color="#FFFFD060" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                            <Rectangle.Effect>
                                <DropShadowEffect Color="#FFD060" BlurRadius="7" ShadowDepth="0" Opacity="0.7"/>
                            </Rectangle.Effect>
                        </Rectangle>
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
        </Border>
    </Grid>
</UserControl>
