<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.SpeedTapeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display">
    <Border Background="{DynamicResource Fh6.Surface}"
            BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
            CornerRadius="10" Padding="10,8">
        <Grid Width="90">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Label -->
            <TextBlock Text="MPH"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" Margin="0,0,0,4"/>

            <!-- Tape area: fixed height, clips, fades at top and bottom -->
            <Grid Grid.Row="1" Height="160">
                <!-- Tick column: contains all the speed marks, translated to scroll -->
                <Canvas x:Name="TapeCanvas" Width="90" Height="160" ClipToBounds="True">
                    <!-- Ticks are populated in code-behind -->
                    <Canvas.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0.0"/>
                            <GradientStop Color="Black"       Offset="0.18"/>
                            <GradientStop Color="Black"       Offset="0.82"/>
                            <GradientStop Color="Transparent" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Canvas.OpacityMask>
                    <Canvas.RenderTransform>
                        <TranslateTransform x:Name="TapeTranslate" Y="0"/>
                    </Canvas.RenderTransform>
                </Canvas>

                <!-- Center cursor: sits at the mid-line, shows current value -->
                <Border VerticalAlignment="Center" HorizontalAlignment="Right"
                        Background="{DynamicResource Fh6.Accent}"
                        CornerRadius="5" Padding="6,3" Margin="0,0,0,0">
                    <TextBlock x:Name="CursorText"
                               Foreground="#04140F" FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                </Border>

                <!-- Triangle pointer on the left side of cursor -->
                <Path VerticalAlignment="Center" HorizontalAlignment="Right"
                      Margin="0,0,66,0"
                      Fill="{DynamicResource Fh6.Accent}">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="8,0" IsClosed="True">
                                <LineSegment Point="0,6"/>
                                <LineSegment Point="0,-6"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Centre reference line -->
                <Rectangle VerticalAlignment="Center" HorizontalAlignment="Stretch"
                           Height="1" Margin="0,0,0,0"
                           Fill="{DynamicResource Fh6.Border}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
