<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.SpeedSlipstreamWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" Height="60"
             SizeChanged="OnSizeChanged"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <!-- Semi-transparent backdrop: streaks read as a speed-convey background panel -->
    <Border Background="#99060A10"
            BorderBrush="#1AFFFFFF" BorderThickness="0,1,0,1">
        <Canvas x:Name="StreamCanvas" ClipToBounds="True"/>
    </Border>
</UserControl>
