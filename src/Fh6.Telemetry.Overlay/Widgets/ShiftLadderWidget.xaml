<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.ShiftLadderWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display">
    <UserControl.Resources>
        <!-- Flash animation for top-redline stage -->
        <Storyboard x:Key="RedlineFlash" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="RedlineOverlay"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1"
                Duration="0:0:0.12"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="10,8">
        <StackPanel>
            <TextBlock Text="RPM"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" Margin="0,0,0,4"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Gradient RPM bar, filled bottom->top by DisplayedRpmFraction -->
                <Grid Width="28" Height="140" Margin="0,0,6,0">
                    <!-- Trough -->
                    <Border Background="#1A2416" CornerRadius="5"/>

                    <!-- Gradient fill — grows from bottom -->
                    <Border x:Name="FillBorder" CornerRadius="5"
                            VerticalAlignment="Bottom" Height="0">
                        <Border.Effect>
                            <DropShadowEffect Color="#E0C93A" BlurRadius="8" ShadowDepth="0" Opacity="0.55"/>
                        </Border.Effect>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                <GradientStop Color="#5AD15A" Offset="0.0"/>
                                <GradientStop Color="#E0C93A" Offset="0.55"/>
                                <GradientStop Color="#E05A5A" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Redline hatching overlay (top portion of bar) — flashes near redline -->
                    <Border x:Name="RedlineOverlay" CornerRadius="5"
                            VerticalAlignment="Top" Height="20"
                            Opacity="0">
                        <Border.Background>
                            <DrawingBrush TileMode="Tile"
                                          Viewport="0,0,8,8" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="#80FF4040">
                                        <GeometryDrawing.Geometry>
                                            <PathGeometry Figures="M0,8 L8,0 M-2,2 L2,-2 M6,10 L10,6"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- Gear pips populated in code-behind (R N 1..7), stacked bottom to top -->
                <ItemsControl x:Name="GearPips" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Use a Canvas so we can control order explicitly -->
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <!-- Current gear label -->
            <TextBlock x:Name="GearLabel"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Fh6.TextPrimary}"
                       FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                       Margin="0,4,0,0"/>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
