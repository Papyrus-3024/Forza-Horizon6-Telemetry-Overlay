<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.ArcTachWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="184" Height="166"
             SizeChanged="OnSizeChanged"
             TextOptions.TextFormattingMode="Display">
    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}" CacheMode="BitmapCache"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="10,8">
            <StackPanel>
                <!-- Shift-light strip — semantic staging colors (bound brushes) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                    <Border x:Name="Led1" Width="16" Height="8" CornerRadius="3" Margin="3,0" Background="{Binding Light1}"/>
                    <Border x:Name="Led2" Width="16" Height="8" CornerRadius="3" Margin="3,0" Background="{Binding Light2}"/>
                    <Border x:Name="Led3" Width="16" Height="8" CornerRadius="3" Margin="3,0" Background="{Binding Light3}"/>
                    <Border x:Name="Led4" Width="16" Height="8" CornerRadius="3" Margin="3,0" Background="{Binding Light4}"/>
                    <Border x:Name="Led5" Width="16" Height="8" CornerRadius="3" Margin="3,0" Background="{Binding Light5}"/>
                </StackPanel>

                <!-- Arc tach + centred gear digit -->
                <Canvas x:Name="ArcField" Width="160" Height="106" HorizontalAlignment="Center">
                    <!-- Background track -->
                    <Path x:Name="TrackArc" Stroke="#16FFFFFF" StrokeThickness="10"
                          Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <!-- Green power band 62–86% (semantic, dim) -->
                    <Path x:Name="BandArc" Stroke="#8C46E08A" StrokeThickness="10" Fill="Transparent"/>
                    <!-- Redline zone 90–100% (semantic, dim) -->
                    <Path x:Name="RedlineArc" Stroke="#99FF4040" StrokeThickness="10" Fill="Transparent"/>
                    <!-- Eased value fill (gradient + glow set in code-behind) -->
                    <Path x:Name="FillArc" StrokeThickness="10" Fill="Transparent"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                        <Path.Stroke>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#3FD07F" Offset="0.0"/>
                                <GradientStop Color="#FFC24B" Offset="0.55"/>
                                <GradientStop Color="#FF4040" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Path.Stroke>
                    </Path>

                    <!-- Centre gear digit + caption -->
                    <StackPanel x:Name="CenterBlock" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="GearText" Text="{Binding Gear}"
                                   FontFamily="Consolas" FontSize="46" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   LineHeight="46" LineStackingStrategy="BlockLineHeight">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFFFFF" Offset="0.0"/>
                                    <GradientStop Color="#FFC8D2DD" Offset="1.0"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="GEAR"
                                   Foreground="{DynamicResource Fh6.TextLabel}"
                                   FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                    </StackPanel>
                </Canvas>

                <!-- RPM readout: "cur / max" -->
                <TextBlock Text="{Binding Rpm}"
                           Foreground="{DynamicResource Fh6.TextSecondary}"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
