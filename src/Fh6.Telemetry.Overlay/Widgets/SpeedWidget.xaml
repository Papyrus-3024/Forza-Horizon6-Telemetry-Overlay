<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.SpeedWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display">
    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}" CacheMode="BitmapCache"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="14,8">
        <StackPanel>
            <TextBlock Text="MPH"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding SpeedMph}"
                       Foreground="{DynamicResource Fh6.TextPrimary}" FontSize="48" FontWeight="Bold" FontFamily="Consolas"
                       LineHeight="48" LineStackingStrategy="BlockLineHeight"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Speed}"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="13" FontFamily="Consolas"/>
                <TextBlock Text=" km/h"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Bottom" Margin="2,0,0,1"/>
            </StackPanel>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
