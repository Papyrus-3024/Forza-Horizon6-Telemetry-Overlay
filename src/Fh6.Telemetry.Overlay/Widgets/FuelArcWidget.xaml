<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.FuelArcWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130" Height="130"
             SizeChanged="OnSizeChanged"
             TextOptions.TextFormattingMode="Display">
    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="8,6">
        <StackPanel>
            <TextBlock Text="FUEL"
                       Foreground="{DynamicResource Fh6.TextLabel}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <Canvas x:Name="ArcField" Width="108" Height="100" HorizontalAlignment="Center">
                <!-- Track arc: full range dim ring -->
                <Path x:Name="TrackArc"
                      Stroke="#22FFFFFF" StrokeThickness="8" Fill="Transparent"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <!-- Fill arc: fuel level, colour-shifts when low -->
                <Path x:Name="FillArc"
                      StrokeThickness="8" Fill="Transparent"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                <!-- Centre value block -->
                <StackPanel x:Name="CenterBlock" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="FuelValue"
                               Foreground="{DynamicResource Fh6.TextPrimary}"
                               FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="%"
                               Foreground="{DynamicResource Fh6.TextSecondary}"
                               FontFamily="Consolas" FontSize="9"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Canvas>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
