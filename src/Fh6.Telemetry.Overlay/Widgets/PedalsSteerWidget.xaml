<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.PedalsSteerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:w="clr-namespace:Fh6.Telemetry.Overlay.Widgets"
             TextOptions.TextFormattingMode="Display">
    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}" CacheMode="BitmapCache"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="12,8">
        <StackPanel>
            <TextBlock Text="PEDALS"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" Margin="0,0,0,5"/>
            <!-- Vertical bars — throttle=green, brake=red, clutch=blue (semantic, kept hardcoded) -->
            <StackPanel Orientation="Horizontal" Height="56" VerticalAlignment="Bottom">
                <ProgressBar Width="16" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding DisplayedThrottle, Mode=OneWay}"
                             Foreground="#5AD15A" Background="#1A2416" BorderThickness="0"/>
                <ProgressBar Width="16" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding DisplayedBrake, Mode=OneWay}"
                             Foreground="#E05A5A" Background="#1A2416" BorderThickness="0"/>
                <ProgressBar Width="16" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding DisplayedClutch, Mode=OneWay}"
                             Foreground="#6AA8E0" Background="#1A2416" BorderThickness="0"/>
            </StackPanel>
            <!-- Labels -->
            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                <TextBlock Text="T" Width="20" TextAlignment="Center" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource Fh6.TextSecondary}" Margin="2,0"/>
                <TextBlock Text="B" Width="20" TextAlignment="Center" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource Fh6.TextSecondary}" Margin="2,0"/>
                <TextBlock Text="C" Width="20" TextAlignment="Center" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource Fh6.TextSecondary}" Margin="2,0"/>
            </StackPanel>
            <!-- Percentage values -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ThrottlePct}" Width="20" TextAlignment="Center"
                           FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource Fh6.TextSecondary}" Margin="2,0"/>
                <TextBlock Text="{Binding BrakePct}" Width="20" TextAlignment="Center"
                           FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource Fh6.TextSecondary}" Margin="2,0"/>
                <TextBlock Text="{Binding ClutchPct}" Width="20" TextAlignment="Center"
                           FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource Fh6.TextSecondary}" Margin="2,0"/>
            </StackPanel>
            <!-- Steering bar — uses accent color via code-behind Fill (separate widget) -->
            <w:SteeringBar Value="{Binding DisplayedSteer, Mode=OneWay}" Height="7" Margin="0,6,0,0"/>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
