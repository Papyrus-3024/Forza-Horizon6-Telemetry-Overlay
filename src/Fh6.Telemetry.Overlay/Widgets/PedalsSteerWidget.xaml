<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.PedalsSteerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:w="clr-namespace:Fh6.Telemetry.Overlay.Widgets">
    <Border Background="#A6080A08" CornerRadius="6" Padding="8,4">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Height="44" VerticalAlignment="Bottom">
                <ProgressBar Width="14" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding Throttle, Mode=OneWay}" Foreground="#5AD15A" Background="#2C3A26" BorderThickness="0"/>
                <ProgressBar Width="14" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding Brake, Mode=OneWay}" Foreground="#E05A5A" Background="#2C3A26" BorderThickness="0"/>
                <ProgressBar Width="14" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding Clutch, Mode=OneWay}" Foreground="#6AA8E0" Background="#2C3A26" BorderThickness="0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="T" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas" Foreground="#CCFFFFFF" Margin="2,0"/>
                <TextBlock Text="B" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas" Foreground="#CCFFFFFF" Margin="2,0"/>
                <TextBlock Text="C" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas" Foreground="#CCFFFFFF" Margin="2,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ThrottlePct}" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas" Foreground="#CCFFFFFF" Margin="2,0"/>
                <TextBlock Text="{Binding BrakePct}" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas" Foreground="#CCFFFFFF" Margin="2,0"/>
                <TextBlock Text="{Binding ClutchPct}" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas" Foreground="#CCFFFFFF" Margin="2,0"/>
            </StackPanel>
            <w:SteeringBar Value="{Binding Steer, Mode=OneWay}" Height="6" Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
