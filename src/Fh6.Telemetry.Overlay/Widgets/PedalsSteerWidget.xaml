<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.PedalsSteerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:w="clr-namespace:Fh6.Telemetry.Overlay.Widgets">
    <Border Background="#C8121821"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            CornerRadius="8" Padding="10,6">
        <Border.Effect>
            <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="10" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="PEDALS"
                       Foreground="#80FFFFFF" FontSize="8" FontFamily="Consolas"
                       Margin="0,0,0,4"/>
            <!-- Vertical bars — bind to Displayed* for smooth animation -->
            <StackPanel Orientation="Horizontal" Height="48" VerticalAlignment="Bottom">
                <ProgressBar Width="14" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding DisplayedThrottle, Mode=OneWay}"
                             Foreground="#5AD15A" Background="#1A2416" BorderThickness="0"/>
                <ProgressBar Width="14" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding DisplayedBrake, Mode=OneWay}"
                             Foreground="#E05A5A" Background="#1A2416" BorderThickness="0"/>
                <ProgressBar Width="14" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding DisplayedClutch, Mode=OneWay}"
                             Foreground="#6AA8E0" Background="#1A2416" BorderThickness="0"/>
            </StackPanel>
            <!-- Labels -->
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                <TextBlock Text="T" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas"
                           Foreground="#80FFFFFF" Margin="2,0"/>
                <TextBlock Text="B" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas"
                           Foreground="#80FFFFFF" Margin="2,0"/>
                <TextBlock Text="C" Width="18" TextAlignment="Center" FontSize="8" FontFamily="Consolas"
                           Foreground="#80FFFFFF" Margin="2,0"/>
            </StackPanel>
            <!-- Percentage values -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ThrottlePct}" Width="18" TextAlignment="Center"
                           FontSize="8" FontFamily="Consolas" Foreground="#99FFFFFF" Margin="2,0"/>
                <TextBlock Text="{Binding BrakePct}" Width="18" TextAlignment="Center"
                           FontSize="8" FontFamily="Consolas" Foreground="#99FFFFFF" Margin="2,0"/>
                <TextBlock Text="{Binding ClutchPct}" Width="18" TextAlignment="Center"
                           FontSize="8" FontFamily="Consolas" Foreground="#99FFFFFF" Margin="2,0"/>
            </StackPanel>
            <!-- Steering bar — binds to DisplayedSteer -->
            <w:SteeringBar Value="{Binding DisplayedSteer, Mode=OneWay}" Height="6" Margin="0,5,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
