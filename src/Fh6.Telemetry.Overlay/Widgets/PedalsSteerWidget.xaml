<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.PedalsSteerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#A6080A08" CornerRadius="6" Padding="8,4">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Height="38" VerticalAlignment="Bottom">
                <ProgressBar Width="10" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding Throttle}" Foreground="#5AD15A" Background="#2C3A26" BorderThickness="0"/>
                <ProgressBar Width="10" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding Brake}" Foreground="#E05A5A" Background="#2C3A26" BorderThickness="0"/>
                <ProgressBar Width="10" Margin="2,0" Orientation="Vertical" Minimum="0" Maximum="1"
                             Value="{Binding Clutch}" Foreground="#6AA8E0" Background="#2C3A26" BorderThickness="0"/>
            </StackPanel>
            <ProgressBar Height="5" Margin="0,4,0,0" Minimum="-1" Maximum="1" Value="{Binding Steer}"
                         Foreground="#E8EEE6" Background="#2C3A26" BorderThickness="0"/>
        </StackPanel>
    </Border>
</UserControl>
