<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.GForceWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="96" Height="100"
             SizeChanged="OnSizeChanged">
    <Border Background="#C8121821"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            CornerRadius="8" Padding="6,5">
        <StackPanel>
            <TextBlock Text="G-FORCE"
                       Foreground="#80FFFFFF" FontSize="8" FontFamily="Consolas"
                       HorizontalAlignment="Center" Margin="0,0,0,3"/>
            <Canvas x:Name="Field" Width="74" Height="74" HorizontalAlignment="Center">
                <!-- 1g reference ring -->
                <Ellipse x:Name="Ring"
                         Stroke="#44FFFFFF" StrokeThickness="1"
                         Fill="Transparent"/>
                <!-- Crosshair -->
                <Line x:Name="HLine" Stroke="#33FFFFFF" StrokeThickness="1"/>
                <Line x:Name="VLine" Stroke="#33FFFFFF" StrokeThickness="1"/>
                <!-- G-force dot — binds to DisplayedGLat/GLong via code-behind -->
                <Ellipse x:Name="Dot"
                         Width="9" Height="9"
                         Fill="#E05A5A"/>
            </Canvas>
            <TextBlock x:Name="GLabel"
                       Text="{Binding GText}"
                       Foreground="#F2F4F7" FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
