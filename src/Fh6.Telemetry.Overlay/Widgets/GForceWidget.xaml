<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.GForceWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="104" Height="110"
             SizeChanged="OnSizeChanged"
             TextOptions.TextFormattingMode="Display">
    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="8,6">
        <StackPanel>
            <TextBlock Text="G-FORCE"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <Canvas x:Name="Field" Width="80" Height="80" HorizontalAlignment="Center">
                <!-- 1g reference ring -->
                <Ellipse x:Name="Ring"
                         Stroke="#44FFFFFF" StrokeThickness="1"
                         Fill="Transparent"/>
                <!-- Crosshair -->
                <Line x:Name="HLine" Stroke="#33FFFFFF" StrokeThickness="1"/>
                <Line x:Name="VLine" Stroke="#33FFFFFF" StrokeThickness="1"/>
                <!-- G-force dot — semantic: changes to danger color near limit (hardcoded in code-behind) -->
                <!-- Fill is set in code-behind (semantic grip color: green/amber/red). -->
                <Ellipse x:Name="Dot"
                         Width="10" Height="10"/>
            </Canvas>
            <TextBlock x:Name="GLabel"
                       Text="{Binding GText}"
                       Foreground="{DynamicResource Fh6.TextPrimary}" FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
