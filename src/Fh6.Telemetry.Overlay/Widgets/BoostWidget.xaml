<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.BoostWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130" Height="148"
             SizeChanged="OnSizeChanged"
             TextOptions.TextFormattingMode="Display">
    <Border Background="{DynamicResource Fh6.Surface}"
            BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
            CornerRadius="10" Padding="10,8">
        <StackPanel>
            <TextBlock Text="BOOST"
                       Foreground="{DynamicResource Fh6.TextLabel}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <!-- Arc dial canvas — code-behind draws the arc and peak tick -->
            <Canvas x:Name="ArcField" Width="108" Height="90" HorizontalAlignment="Center">
                <!-- Track arc: static dim ring — drawn in code-behind -->
                <Path x:Name="TrackArc"  Stroke="#22FFFFFF" StrokeThickness="8"
                      Fill="Transparent"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <!-- Fill arc: eased boost level -->
                <Path x:Name="FillArc"   StrokeThickness="8"
                      Fill="Transparent"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <!-- Peak-hold tick -->
                <Line x:Name="PeakTick" StrokeThickness="2" Stroke="#CCFFFF80"
                      Visibility="Collapsed"/>

                <!-- Center value -->
                <StackPanel x:Name="CenterBlock"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="BoostValue"
                               Foreground="{DynamicResource Fh6.TextPrimary}"
                               FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="psi"
                               Foreground="{DynamicResource Fh6.TextSecondary}"
                               FontFamily="Consolas" FontSize="9"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Canvas>

            <!-- Fuel row — compact line below the dial -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                <TextBlock Text="FUEL "
                           Foreground="{DynamicResource Fh6.TextLabel}" FontSize="9" FontFamily="Consolas"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Fuel}"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
