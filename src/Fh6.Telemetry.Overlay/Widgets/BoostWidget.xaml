<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.BoostWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display">
    <Border Background="{DynamicResource Fh6.Surface}"
            BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
            CornerRadius="10" Padding="12,8">
        <StackPanel>
            <TextBlock Text="BOOST"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Boost}"
                           Foreground="{DynamicResource Fh6.TextPrimary}" FontSize="24" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Text=" psi"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Bottom" Margin="3,0,0,3"/>
            </StackPanel>
            <TextBlock Text="FUEL"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding Fuel}"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="13" FontFamily="Consolas"/>
        </StackPanel>
    </Border>
</UserControl>
