<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.GearWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:w="clr-namespace:Fh6.Telemetry.Overlay.Widgets"
             TextOptions.TextFormattingMode="Display">
    <UserControl.Resources>
        <!-- Slide-in: new digit enters from below (slides up into position) -->
        <Storyboard x:Key="DrumRoll">
            <!-- Start offset below, end at zero (natural position) -->
            <DoubleAnimation
                Storyboard.TargetName="GearTranslate"
                Storyboard.TargetProperty="Y"
                From="56" To="0"
                Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="14,8"
                ClipToBounds="True">
        <StackPanel>
            <TextBlock Text="GEAR"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold"/>
            <!-- Clipping container so the outgoing digit doesn't overflow the panel -->
            <Grid Height="52" ClipToBounds="True">
                <TextBlock x:Name="GearText"
                           Text="{Binding Gear}"
                           Foreground="{DynamicResource Fh6.TextPrimary}" FontSize="52" FontWeight="Bold" FontFamily="Consolas"
                           LineHeight="52" LineStackingStrategy="BlockLineHeight">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="GearTranslate" Y="0"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
