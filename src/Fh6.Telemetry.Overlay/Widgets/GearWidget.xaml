<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.GearWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#A6080A08" CornerRadius="6" Padding="8,4">
        <StackPanel>
            <TextBlock Text="GEAR" Foreground="#99FFFFFF" FontSize="9" FontFamily="Consolas"/>
            <TextBlock Text="{Binding Gear}" Foreground="White" FontSize="30" FontWeight="Bold" FontFamily="Consolas"/>
        </StackPanel>
    </Border>
</UserControl>
