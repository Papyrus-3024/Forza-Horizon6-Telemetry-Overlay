<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.GearWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:w="clr-namespace:Fh6.Telemetry.Overlay.Widgets">
    <Border Background="#C8121821"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            CornerRadius="8" Padding="10,6">
        <StackPanel>
            <TextBlock Text="GEAR"
                       Foreground="#80FFFFFF" FontSize="8" FontFamily="Consolas"/>
            <TextBlock Text="{Binding Gear}"
                       Foreground="#F2F4F7" FontSize="36" FontWeight="Bold" FontFamily="Consolas"/>
        </StackPanel>
    </Border>
</UserControl>
