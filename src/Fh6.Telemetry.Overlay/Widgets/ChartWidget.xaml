<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.ChartWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" Height="180">
    <Border Background="#C8121821"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            CornerRadius="8" Padding="6,5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="72"/>
            </Grid.ColumnDefinitions>

            <!-- Plot area -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="TRACE"
                           Foreground="#80FFFFFF" FontSize="8" FontFamily="Consolas"
                           HorizontalAlignment="Left" Margin="0,0,0,3"/>
                <!-- Canvas where Path geometry is drawn -->
                <Canvas x:Name="Plot" Grid.Row="1"
                        ClipToBounds="True"/>
            </Grid>

            <!-- Legend panel -->
            <StackPanel x:Name="Legend" Grid.Column="1"
                        Margin="6,14,0,0"
                        VerticalAlignment="Top"/>
        </Grid>
    </Border>
</UserControl>
