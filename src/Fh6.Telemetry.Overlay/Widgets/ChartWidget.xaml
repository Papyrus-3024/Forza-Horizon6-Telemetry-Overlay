<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.ChartWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" Height="180"
             TextOptions.TextFormattingMode="Display">
    <Border Background="{DynamicResource Fh6.Surface}"
            BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
            CornerRadius="10" Padding="8,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="72"/>
            </Grid.ColumnDefinitions>

            <!-- Plot area -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="TRACE"
                           Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                           FontWeight="Bold"
                           HorizontalAlignment="Left" Margin="0,0,0,4"/>
                <!-- Canvas where Path geometry is drawn -->
                <Canvas x:Name="Plot" Grid.Row="1"
                        ClipToBounds="True"/>
            </Grid>

            <!-- Legend panel -->
            <StackPanel x:Name="Legend" Grid.Column="1"
                        Margin="6,16,0,0"
                        VerticalAlignment="Top"/>
        </Grid>
    </Border>
</UserControl>
