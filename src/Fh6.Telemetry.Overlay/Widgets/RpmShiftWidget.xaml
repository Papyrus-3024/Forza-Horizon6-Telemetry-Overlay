<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.RpmShiftWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#A6080A08" CornerRadius="6" Padding="8,4">
        <StackPanel MinWidth="150">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                <Ellipse Width="9" Height="9" Margin="2,0" Fill="{Binding Light1}"/>
                <Ellipse Width="9" Height="9" Margin="2,0" Fill="{Binding Light2}"/>
                <Ellipse Width="9" Height="9" Margin="2,0" Fill="{Binding Light3}"/>
                <Ellipse Width="9" Height="9" Margin="2,0" Fill="{Binding Light4}"/>
                <Ellipse Width="9" Height="9" Margin="2,0" Fill="{Binding Light5}"/>
            </StackPanel>
            <TextBlock Text="{Binding Rpm}" Foreground="#99FFFFFF" FontSize="9" FontFamily="Consolas"/>
            <ProgressBar Height="7" Minimum="0" Maximum="1" Value="{Binding RpmFraction, Mode=OneWay}"
                         Background="#2C3A26" BorderThickness="0">
                <ProgressBar.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#5AD15A" Offset="0.0"/>
                        <GradientStop Color="#E0C93A" Offset="0.6"/>
                        <GradientStop Color="#E05A5A" Offset="1.0"/>
                    </LinearGradientBrush>
                </ProgressBar.Foreground>
            </ProgressBar>
        </StackPanel>
    </Border>
</UserControl>
