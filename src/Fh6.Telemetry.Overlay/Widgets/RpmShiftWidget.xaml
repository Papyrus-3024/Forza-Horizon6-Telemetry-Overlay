<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.RpmShiftWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display">
    <Grid>
        <!-- Shadow + surface layer (no text → keeps content ClearType crisp) -->
        <Border Background="{DynamicResource Fh6.Surface}"
                BorderBrush="{DynamicResource Fh6.Border}" BorderThickness="1"
                CornerRadius="10" Effect="{StaticResource Fh6.PanelShadow}" CacheMode="BitmapCache"/>
        <!-- Content layer -->
        <Border CornerRadius="10" Padding="12,8">
        <StackPanel MinWidth="170">
            <!-- Shift-light dots — semantic staging colors kept hardcoded (green→amber→red) -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5" HorizontalAlignment="Center">
                <Ellipse Width="12" Height="12" Margin="4,0" Fill="{Binding Light1}"/>
                <Ellipse Width="12" Height="12" Margin="4,0" Fill="{Binding Light2}"/>
                <Ellipse Width="12" Height="12" Margin="4,0" Fill="{Binding Light3}"/>
                <Ellipse Width="12" Height="12" Margin="4,0" Fill="{Binding Light4}"/>
                <Ellipse Width="12" Height="12" Margin="4,0" Fill="{Binding Light5}"/>
            </StackPanel>
            <!-- RPM label -->
            <TextBlock Text="RPM"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="9" FontFamily="Consolas"
                       FontWeight="Bold" Margin="0,0,0,2"/>
            <!-- RPM value -->
            <TextBlock Text="{Binding Rpm}"
                       Foreground="{DynamicResource Fh6.TextSecondary}" FontSize="10" FontFamily="Consolas"
                       Margin="0,0,0,4"/>
            <!-- Gradient RPM bar — semantic green→amber→red gradient kept hardcoded -->
            <ProgressBar Height="10" Minimum="0" Maximum="1"
                         Value="{Binding DisplayedRpmFraction, Mode=OneWay}"
                         Background="#1A2416" BorderThickness="0">
                <ProgressBar.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#5AD15A" Offset="0.0"/>
                        <GradientStop Color="#E0C93A" Offset="0.6"/>
                        <GradientStop Color="#E05A5A" Offset="1.0"/>
                    </LinearGradientBrush>
                </ProgressBar.Foreground>
            </ProgressBar>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
