<UserControl x:Class="Fh6.Telemetry.Overlay.Widgets.SteeringBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SizeChanged="OnSizeChanged">
    <Canvas x:Name="Root" Height="6" Background="#1A2416" ClipToBounds="True">
        <Rectangle x:Name="Fill" Height="6" Fill="#E8EEE6"/>
        <Rectangle x:Name="CenterTick" Width="1" Height="6" Fill="#88FFFFFF"/>
    </Canvas>
</UserControl>
