<UserControl x:Class="Fh6.Telemetry.Overlay.Layouts.CornerPanelLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:w="clr-namespace:Fh6.Telemetry.Overlay.Widgets">
    <StackPanel Width="170">
        <StackPanel Orientation="Horizontal">
            <w:GearWidget Margin="3"/>
            <w:SpeedWidget Margin="3"/>
        </StackPanel>
        <w:RpmShiftWidget Margin="3"/>
        <StackPanel Orientation="Horizontal">
            <w:PedalsSteerWidget Margin="3"/>
            <w:BoostWidget Margin="3"/>
        </StackPanel>
        <w:LapTimingWidget Margin="3"/>
    </StackPanel>
</UserControl>
